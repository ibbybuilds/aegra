# GKE Production Environment Configuration
# Configure these variables as Kubernetes secrets or via GCP Secret Manager

# Database - GCP Cloud SQL for PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
# For Cloud SQL Proxy: postgresql+asyncpg://user:password@127.0.0.1:5432/aegra
# For Private IP: postgresql+asyncpg://user:password@PRIVATE_IP:5432/aegra
DATABASE_URL=postgresql+asyncpg://aegra_user:SECURE_PASSWORD@10.x.x.x:5432/aegra_prod

# Redis - GCP Memorystore for Redis (optional)
# REDIS_URL=redis://10.x.x.x:6379

# Authentication - Use 'custom' for production
AUTH_TYPE=custom

# JWT Authentication (REQUIRED for AUTH_TYPE=custom)
# Generate secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Store AEGRA_JWT_SECRET in GCP Secret Manager for production
AEGRA_JWT_ALGORITHM=HS256
AEGRA_JWT_SECRET=CHANGE-TO-PRODUCTION-SECRET-256-BIT
AEGRA_JWT_ISSUERS=conversation-relay,transcript-service  # Comma-separated list of trusted issuers
AEGRA_JWT_AUDIENCE=aegra
AEGRA_JWT_VERIFY_EXPIRATION=true
AEGRA_JWT_LEEWAY_SECONDS=30

# Server Configuration
PORT=8000
DEBUG=false

# LLM Providers - Production API keys
OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# TOGETHER_API_KEY=...

# Langfuse Observability (highly recommended for production monitoring)
LANGFUSE_LOGGING=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# API BASE URLS (for ava_v1 graph)

# Pinecone vector search service for hotel name resolution
# IMPORTANT: Configure production Pinecone service URL
PINECONE_SERVICE_URL=https://pinecone-service-production.example.com

# Security & Performance
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# MAX_WORKERS=4
# LOG_LEVEL=INFO

# GCP-specific (if using GCP services beyond Cloud SQL)
# GCP_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/gcp-service-account.json
