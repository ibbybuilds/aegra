# Railway Staging Environment Configuration
# Configure these variables in the Railway dashboard for your staging environment

# Database - Railway will auto-provide this when you add a PostgreSQL service
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://railway_user:password@railway.internal:5432/railway

# Database Connection Pool (Staging Tuning)
# Updated 2026-02-04 for capacity testing and load validation
# Staging uses same configuration as production for realistic testing
DB_POOL_SIZE=150             # Persistent connections (handles 90+ SSE streams + regular traffic)
DB_MAX_OVERFLOW=50           # Burst capacity (total max = 200 connections)
DB_POOL_TIMEOUT=60           # Wait time for available connection
DB_POOL_RECYCLE=3600         # Recycle after 1 hour (prevents stale connections)
DB_POOL_PRE_PING=true        # Health check before use (prevents "connection closed" errors)

# Redis (optional) - Uncomment if using Redis service
# REDIS_URL=redis://default:password@redis.railway.internal:6379

# Authentication
# JWT authentication enabled in staging (matching production)
AUTH_TYPE=custom

# JWT Authentication (for AUTH_TYPE=custom)
# Generate secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Configure in Railway dashboard as environment variables
AEGRA_JWT_ALGORITHM=HS256
AEGRA_JWT_SECRET=CHANGE-TO-STAGING-SECRET-256-BIT
AEGRA_JWT_ISSUERS=conversation-relay,transcript-service  # Comma-separated list of trusted issuers
AEGRA_JWT_AUDIENCE=aegra-staging
AEGRA_JWT_VERIFY_EXPIRATION=true
AEGRA_JWT_LEEWAY_SECONDS=30

# Server Configuration
# Railway automatically sets PORT - this is for reference only
PORT=8000
DEBUG=true

# LLM Providers - Add the provider you're using
OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# TOGETHER_API_KEY=...

# Langfuse Observability (optional but recommended for staging)
LANGFUSE_LOGGING=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# API BASE URLS (for ava_v1 graph)
CACHE_WORKER_URL=https://cache-worker-staging.up.railway.app

# Pinecone vector search service for hotel name resolution
PINECONE_SERVICE_URL=https://pinecone-service-local-staging-4870.up.railway.app

# Cache-worker JWT Authentication
CACHE_WORKER_JWT_SECRET=CHANGE-TO-STAGING-SECRET-256-BIT
CACHE_WORKER_JWT_ISSUER=aegra
CACHE_WORKER_JWT_AUDIENCE=cache-worker
CACHE_WORKER_JWT_ENABLED=true
