# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aegra

# Database Connection Pool (Production Tuning)
# Defaults are suitable for internal service with moderate load (20-30 concurrent conversations)
DB_POOL_SIZE=20              # Max persistent connections in pool
DB_MAX_OVERFLOW=10           # Additional connections for bursts (total max = pool_size + max_overflow)
DB_POOL_TIMEOUT=30           # Seconds to wait for available connection
DB_POOL_RECYCLE=3600         # Recycle connections after 1 hour (prevents stale connections)
DB_POOL_PRE_PING=true        # Verify connection health before use

# Authentication (extensible)
# noop, custom
AUTH_TYPE=noop

# JWT Authentication (for AUTH_TYPE=custom)
# Generate secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AEGRA_JWT_ALGORITHM=HS256
AEGRA_JWT_SECRET=dev-secret-change-in-production-use-256-bit-key
AEGRA_JWT_ISSUERS=conversation-relay,transcript-service  # Comma-separated list of trusted issuers
AEGRA_JWT_AUDIENCE=aegra-dev
AEGRA_JWT_VERIFY_EXPIRATION=true
AEGRA_JWT_LEEWAY_SECONDS=30  

# Server
HOST=0.0.0.0                     # Bind to all IPv4 interfaces (Railway/Docker compatible)
PORT=8000
DEBUG=true

# Logging
LOG_LEVEL=INFO
ENV_MODE=LOCAL # DEVELOPMENT, PRODUCTION, LOCAL (PRODUCTION outputs JSON logs)
LOG_VERBOSITY=standard # standard, verbose (verbose outputs request-id for each request)

# Redis (Required for ava_v1 graph)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty for no password (local dev)
REDIS_DB=0

# LLM Providers
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# TOGETHER_API_KEY=...

# Internet Search (Required for internet_search tool)
TAVILY_API_KEY=tvly-...

LANGFUSE_LOGGING=true
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# API BASE URLS (for ava_v1 graph)

# Pinecone vector search service for hotel name resolution (ava_v1)
PINECONE_SERVICE_URL=https://pinecone-service-local-staging-4870.up.railway.app

# Reservation Portal URL Generation (for ava_v1 live-handoff)
RESERVATION_PORTAL_BASE_URL=https://sandbox.reservationsportal.com

# Email Validation (tiered approach for cost optimization)
# Free checks always run: syntax, disposable blocklist, MX records, trusted providers
# IPQS API only called for unknown domains from first-time customers
# Get API key from: https://www.ipqualityscore.com/user/api-keys
IPQUALITYSCORE_API_KEY=

# CRM/Booking History API (for repeat customer check - optional)
# TODO: Add CRM endpoint configuration when available
# CRM_API_URL=
# CRM_API_KEY=

# Cache-worker service (required for ava_v1 graph)
CACHE_WORKER_URL=http://localhost:8080

# Cache-worker JWT Authentication (production only)
# Generate secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CACHE_WORKER_JWT_SECRET=  # Required in production/staging, optional in local
CACHE_WORKER_JWT_ISSUER=aegra
CACHE_WORKER_JWT_AUDIENCE=cache-worker
CACHE_WORKER_JWT_ENABLED=false  # Auto-enabled in production (ENV_MODE=PRODUCTION)
CACHE_WORKER_JWT_EXPIRY_SECONDS=3600  # Token lifetime (1 hour)

# Google Model Armor (Content Policy Enforcement)
# Middleware that sanitizes user prompts and model responses using Google's content policy API
# Auto-enabled in production (ENV_MODE=PRODUCTION), disabled by default in local/development
MODEL_ARMOR_ENABLED=false  # Explicit override (auto-enabled in PRODUCTION)
MODEL_ARMOR_PROJECT_ID=your-gcp-project-id
MODEL_ARMOR_LOCATION=us-central1
MODEL_ARMOR_TEMPLATE_ID=your-template-id

# Authentication (choose ONE method):
# Method 1: Service account JSON file path (not recommended for production)
# MODEL_ARMOR_SERVICE_ACCOUNT_PATH=/path/to/service-account-key.json

# Method 2: Service account JSON in environment variable (for Railway/Cloud Run)
# MODEL_ARMOR_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Method 3: Application Default Credentials (for local dev with gcloud CLI)
# Leave both above empty to use: gcloud auth application-default login

MODEL_ARMOR_TIMEOUT=5.0  # API timeout in seconds (max 30)
MODEL_ARMOR_LOG_VIOLATIONS=true  # Log violation details for analysis
MODEL_ARMOR_FAIL_OPEN=false  # Allow requests if API unavailable (true=fail-open, false=fail-closed)
